# Telegram Bot token from @BotFather
BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# Public URL of the Next.js Mini App frontend
WEBAPP_URL=https://wine-mini-app.vercel.app

# OpenAI API key (for GPT-4 Vision wine label analysis)
OPENAI_API_KEY=sk-your-openai-api-key-here

# Server port (optional, defaults to 3001)
PORT=3001
